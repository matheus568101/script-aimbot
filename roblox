-- // CONFIGURAÇÕES INICIAIS
local fov = 100
local smoothing = 0.32
local predictionFactor = 0.08
local teamCheck = false
local lockPart = "HumanoidRootPart"
local aimbotEnabled = true
local ToggleKey = Enum.KeyCode.Q
local MenuKey = Enum.KeyCode.K

local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- // GARANTIR QUE A GUI EXISTA
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AimbotSystem"
screenGui.Parent = localPlayer:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

-- // CRIAÇÃO DO MENU
local mainFrame = Instance.new("Frame")
mainFrame.Name = "MainFrame"
mainFrame.Parent = screenGui
mainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
mainFrame.BorderSizePixel = 0
mainFrame.Position = UDim2.new(0.5, -100, 0.5, -125)
mainFrame.Size = UDim2.new(0, 200, 0, 250)
mainFrame.Visible = false -- Começa invisível, aperte K para abrir

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = ToolAddressValue -- 8 pixels
uiCorner.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Parent = mainFrame
title.Size = UDim2.new(1, 0, 0, 40)
title.Text = "MENU AIMBOT"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.TextSize = 16

-- // FUNÇÃO PARA CRIAR BOTÕES RAPIDAMENTE
local function createMenuButton(text, pos, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = mainFrame
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- // BOTÕES
local toggleBtn = createMenuButton("Aimbot: ON", UDim2.new(0.05, 0, 0, 50), function()
    aimbotEnabled = not aimbotEnabled
    mainFrame.AimbotToggle.Text = aimbotEnabled and "Aimbot: ON" or "Aimbot: OFF"
end)
toggleBtn.Name = "AimbotToggle"

createMenuButton("Time: " .. (teamCheck and "ON" or "OFF"), UDim2.new(0.05, 0, 0, 95), function()
    teamCheck = not teamCheck
    -- Atualiza o texto internamente se necessário
end)

createMenuButton("FOV +", UDim2.new(0.05, 0, 0, 140), function()
    fov = fov + 20
end)

createMenuButton("FOV -", UDim2.new(0.05, 0, 0, 185), function()
    fov = math.max(10, fov - 20)
end)

-- // LÓGICA DA TECLA K PARA ABRIR
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == MenuKey then
        mainFrame.Visible = not mainFrame.Visible
    end
end)

-- // DESENHO DO CÍRCULO (FOV)
local FOVring = Drawing.new("Circle")
FOVring.Visible = true
FOVring.Thickness = 1
FOVring.Transparency = 0.8
FOVring.Color = Color3.fromRGB(255, 255, 255)

-- // LÓGICA DO AIMBOT
local toggleState = false
local currentTarget = nil

local function getClosestPlayer()
    local target = nil
    local shortestDistance = math.huge
    local screenCenter = workspace.CurrentCamera.ViewportSize / 2

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= localPlayer and v.Character and v.Character:FindFirstChild(lockPart) then
            if not teamCheck or v.Team ~= localPlayer.Team then
                local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(v.Character[lockPart].Position)
                local distance = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude

                if onScreen and distance <= fov then
                    if distance < shortestDistance then
                        shortestDistance = distance
                        target = v
                    end
                end
            end
        end
    end
    return target
end

-- // LOOP DE ATUALIZAÇÃO
RunService.RenderStepped:Connect(function()
    -- Atualiza o círculo
    FOVring.Radius = fov
    FOVring.Position = workspace.CurrentCamera.ViewportSize / 2
    FOVring.Visible = aimbotEnabled

    if aimbotEnabled then
        -- Ativa/Desativa com Q
        if UserInputService:IsKeyDown(ToggleKey) then
            toggleState = true
        else
            toggleState = false
        end

        if toggleState then
            currentTarget = getClosestPlayer()
            if currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild(lockPart) then
                local cam = workspace.CurrentCamera
                local targetPos = currentTarget.Character[lockPart].Position
                local targetVelocity = currentTarget.Character[lockPart].Velocity
                local predictedPos = targetPos + (targetVelocity * predictionFactor)

                cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, predictedPos), smoothing)
                FOVring.Color = Color3.fromRGB(0, 255, 0)
            end
        else
            currentTarget = nil
            FOVring.Color = Color3.fromRGB(255, 255, 255)
        end
    else
        FOVring.Visible = false
    end
end)
