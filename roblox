-- // CONFIGURAÇÕES INICIAIS
local teamCheck = false
local fov = 100
local smoothing = 0.32
local predictionFactor = 0.08
local highlightEnabled = false
local lockPart = "HumanoidRootPart"
local aimbotEnabled = true
local Toggle = true 
local ToggleKey = Enum.KeyCode.Q
local MenuKey = Enum.KeyCode.K -- Tecla para abrir o menu

-- // SERVIÇOS
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- // CRIAÇÃO DO MENU (GUI)
local sgui = Instance.new("ScreenGui", localPlayer.PlayerGui)
sgui.Name = "AimbotMenu"
sgui.ResetOnSpawn = false

local frame = Instance.new("Frame", sgui)
frame.Size = UDim2.new(0, 220, 0, 280)
frame.Position = UDim2.new(0.5, -110, 0.5, -140)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.BorderSizePixel = 0
frame.Visible = false -- Começa invisível

local corner = Instance.new("UICorner", frame)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1, 0, 0, 40)
title.Text = "Aimbot Settings (K)"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold

-- Função auxiliar para criar botões no menu
local function createButton(name, pos, callback)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = pos
    btn.Text = name
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- // BOTÕES DO MENU
local btnToggle = createButton("Aimbot: ON", UDim2.new(0.05, 0, 0, 50), function(b)
    aimbotEnabled = not aimbotEnabled
    script.Parent.Text = aimbotEnabled and "Aimbot: ON" or "Aimbot: OFF"
end)

createButton("Team Check: OFF", UDim2.new(0.05, 0, 0, 95), function()
    teamCheck = not teamCheck
    -- Aqui você pode atualizar o texto do botão se desejar
end)

createButton("Aumentar FOV (+20)", UDim2.new(0.05, 0, 0, 140), function()
    fov = fov + 20
    FOVring.Radius = fov
end)

createButton("Diminuir FOV (-20)", UDim2.new(0.05, 0, 0, 185), function()
    fov = math.max(0, fov - 20)
    FOVring.Radius = fov
end)

createButton("Fechar Menu", UDim2.new(0.05, 0, 0, 230), function()
    frame.Visible = false
end)

-- // LÓGICA DE ABRIR COM "K"
UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == MenuKey then
        frame.Visible = not frame.Visible
    end
end)

-- // CÓDIGO DO AIMBOT (ESTRUTURA ORIGINAL)
local FOVring = Drawing.new("Circle")
FOVring.Visible = true
FOVring.Thickness = 1
FOVring.Radius = fov
FOVring.Transparency = 0.8
FOVring.Color = Color3.fromRGB(255, 128, 128)

local currentTarget = nil
local toggleState = false
local debounce = false

local function getClosest(cframe)
    local target = nil
    local mag = math.huge
    local screenCenter = workspace.CurrentCamera.ViewportSize / 2
    local ray = Ray.new(cframe.Position, cframe.LookVector).Unit

    for _, v in pairs(Players:GetPlayers()) do
        if v.Character and v.Character:FindFirstChild(lockPart) and v ~= localPlayer then
            if not teamCheck or v.Team ~= localPlayer.Team then
                local screenPoint, onScreen = workspace.CurrentCamera:WorldToViewportPoint(v.Character[lockPart].Position)
                local dist = (Vector2.new(screenPoint.X, screenPoint.Y) - screenCenter).Magnitude

                if onScreen and dist <= fov then
                    local magBuf = (v.Character[lockPart].Position - ray:ClosestPoint(v.Character[lockPart].Position)).Magnitude
                    if magBuf < mag then
                        mag = magBuf
                        target = v
                    end
                end
            end
        end
    end
    return target
end

-- // LOOP PRINCIPAL
RunService.RenderStepped:Connect(function()
    FOVring.Position = workspace.CurrentCamera.ViewportSize / 2
    
    if aimbotEnabled then
        if Toggle then
            if UserInputService:IsKeyDown(ToggleKey) then
                if not debounce then
                    debounce = true
                    toggleState = not toggleState
                    task.wait(0.3)
                    debounce = false
                end
            end
        else
            toggleState = UserInputService:IsKeyDown(ToggleKey)
        end

        if toggleState then
            local cam = workspace.CurrentCamera
            if not currentTarget then
                currentTarget = getClosest(cam.CFrame)
            end

            if currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild(lockPart) then
                local pos = currentTarget.Character[lockPart].Position
                local velocity = currentTarget.Character[lockPart].Velocity
                local predictedPos = pos + (velocity * predictionFactor)
                
                cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, predictedPos), smoothing)
                FOVring.Color = Color3.fromRGB(0, 255, 0)
            else
                FOVring.Color = Color3.fromRGB(255, 128, 128)
            end
        else
            currentTarget = nil
            FOVring.Color = Color3.fromRGB(255, 128, 128)
        end
    else
        FOVring.Visible = false
    end
end)
